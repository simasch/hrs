@startuml Use Cases Overview
left to right direction

actor "Guest" as guest
actor "Receptionist" as receptionist
actor "Manager" as manager
actor "Housekeeping" as housekeeping
actor "Scheduler" as scheduler

rectangle "Hotel Reservation System" {
    usecase "UC-001\nSearch Available Rooms" as UC001
    usecase "UC-002\nReserve Room" as UC002
    usecase "UC-003\nSend Booking Confirmation" as UC003
    usecase "UC-004\nCheck In Guest" as UC004
    usecase "UC-005\nCheck Out Guest" as UC005
    usecase "UC-006\nManage Room Status" as UC006
    usecase "UC-007\nCancel Reservation" as UC007
    usecase "UC-008\nGenerate Occupancy Report" as UC008
    usecase "UC-009\nSend Arrival Reminder" as UC009
    usecase "UC-010\nUpdate Room Status" as UC010
}

guest --> UC001
guest --> UC002
guest --> UC007

receptionist --> UC004
receptionist --> UC005

manager --> UC008

housekeeping --> UC010

scheduler --> UC009

UC002 ..> UC003 : <<include>>
UC004 ..> UC006 : <<include>>
UC005 ..> UC006 : <<include>>
UC010 ..> UC006 : <<include>>

@enduml
